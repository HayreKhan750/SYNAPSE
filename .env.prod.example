# ============================================================
# SYNAPSE — Production Environment Variables
# ============================================================
# Copy to .env.prod on your server and fill in real values.
# NEVER commit .env.prod to version control.
# ============================================================

# ── Django ────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=generate-with-openssl-rand-base64-50
DEBUG=False
ALLOWED_HOSTS=synapse.app,www.synapse.app,api.synapse.app

# ── Database ──────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=synapse_db
DB_USER=synapse_user
DB_PASSWORD=strong-random-password-here
DB_CONN_MAX_AGE=60

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://:strong-redis-password@redis:6379/0
CELERY_BROKER_URL=redis://:strong-redis-password@redis:6379/1
REDIS_PASSWORD=strong-redis-password

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://synapse.app,https://www.synapse.app

# ── AI Services ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=...
ANTHROPIC_API_KEY=...

# ── Google Drive OAuth2 ───────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://api.synapse.app/api/v1/integrations/drive/callback/

# ── AWS S3 ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_STORAGE_BUCKET_NAME=synapse-media-prod
AWS_S3_REGION_NAME=us-east-1
AWS_PRESIGNED_URL_EXPIRY=3600

# ── Email (SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=SG....
DEFAULT_FROM_EMAIL=noreply@synapse.app

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
SENTRY_TRACES_RATE=0.1
SENTRY_PROFILES_RATE=0.05

# ── Docker / Deployment ───────────────────────────────────────
IMAGE_TAG=latest
GITHUB_REPOSITORY=hayrekhan750/synapse
GUNICORN_WORKERS=4
UVICORN_WORKERS=2
CELERY_CONCURRENCY=4

# ── Flower monitoring ─────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=strong-flower-password

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.synapse.app

# ── SSL Certificates ──────────────────────────────────────────
SSL_CERT_PATH=/etc/letsencrypt/live/synapse.app
DOMAIN=synapse.app
